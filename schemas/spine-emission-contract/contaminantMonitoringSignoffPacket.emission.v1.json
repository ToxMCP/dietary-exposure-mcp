{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.ngra.ai/dietary-exposure/emission/contaminantMonitoringSignoffPacket.v1.json",
  "title": "ContaminantMonitoringSignoffPacket (producer strict emission contract)",
  "description": "Tightened additionalProperties:false mirror of docs/contracts/schemas/contaminantMonitoringSignoffPacket.v1.json, declaring EXACTLY the top-level field set the real DietaryRuntime.export_contaminant_monitoring_signoff_packet seam emits (by_alias=True). Load-bearing review-arm fields the projection reads (overallSignoffStatus, unresolvedBlockingActionIds, reviewerId/reviewerRole, overallSubmissionUse, notes[] narrative) are constrained; embedded action records the projection does not deep-read are declared by type only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overallSignoffStatus",
    "reviewerId",
    "reviewerRole",
    "sourceBundleId",
    "contaminantFamily",
    "jurisdiction",
    "overallSubmissionUse",
    "submissionCandidateAllowed"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "packet_id": { "type": "string" },
    "overallSignoffStatus": { "enum": ["open", "signed_off", "signed_off_with_waivers"] },
    "reviewerId": { "type": "string", "minLength": 1 },
    "reviewerRole": { "type": "string", "minLength": 1 },
    "sourceBundleId": { "type": "string", "minLength": 1 },
    "contaminantFamily": { "type": "string", "minLength": 1 },
    "jurisdiction": { "type": "string", "minLength": 1 },
    "authority": { "type": ["string", "null"] },
    "datasetId": { "type": ["string", "null"] },
    "overallSubmissionUse": { "enum": ["allowed", "review_required", "not_allowed"] },
    "submissionCandidateAllowed": { "type": "boolean" },
    "reportingProfileSummary": { "type": ["object", "null"] },
    "legalLimitReviews": { "type": "array" },
    "actionItems": { "type": "array" },
    "pendingActionIds": { "type": "array", "items": { "type": "string" } },
    "acknowledgedActionIds": { "type": "array", "items": { "type": "string" } },
    "completedActionIds": { "type": "array", "items": { "type": "string" } },
    "waivedActionIds": { "type": "array", "items": { "type": "string" } },
    "unresolvedBlockingActionIds": { "type": "array", "items": { "type": "string" } },
    "referencedResources": { "type": "array" },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
