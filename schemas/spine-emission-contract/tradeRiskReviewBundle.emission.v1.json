{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.ngra.ai/dietary-exposure/emission/tradeRiskReviewBundle.v1.json",
  "title": "tradeRiskReviewBundle (producer strict emission contract)",
  "description": "Tightened additionalProperties:false mirror of the real DietaryRuntime.export_trade_risk_review_bundle emission (by_alias=True). The embedded tradeReport (GlobalTradeRiskReport) carries its own server-authored notes[], deep-scanned by the projection alongside the bundle notes[]/limitations[]. reviewStatus + notes[]/limitations[] are constrained.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reviewStatus",
    "tradeReport"
  ],
  "properties": {
    "bundleId": {
      "type": "string"
    },
    "bundleProfile": {
      "type": "string"
    },
    "coveredSourceIds": {
      "type": "array"
    },
    "dependencies": {
      "type": "array"
    },
    "documentationResourceUri": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "referencedResources": {
      "type": "array"
    },
    "reviewPrompts": {
      "type": "array"
    },
    "reviewStatus": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string"
    },
    "tradeReport": {
      "type": "object"
    }
  }
}
