{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.ngra.ai/dietary-exposure/emission/metalsMonitoringSignoffPacket.v1.json",
  "title": "metalsMonitoringSignoffPacket (producer strict emission contract)",
  "description": "Tightened additionalProperties:false mirror of the real DietaryRuntime.export_metals_monitoring_signoff_packet emission (by_alias=True). The proven laundering channel: a SIGNED_OFF overallSignoffStatus alongside a non-empty unresolvedBlockingActionIds and an unchecked packet_note in notes[]. Load-bearing review-arm fields (overallSignoffStatus, unresolvedBlockingActionIds, notes[]) are constrained.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overallSignoffStatus",
    "reviewerId",
    "reviewerRole",
    "contaminantFamily"
  ],
  "properties": {
    "acknowledgedActionIds": {
      "type": "array"
    },
    "actionItems": {
      "type": "array"
    },
    "authority": {
      "type": [
        "string",
        "null"
      ]
    },
    "completedActionIds": {
      "type": "array"
    },
    "contaminantFamily": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string"
    },
    "legalLimitReviews": {
      "type": "array"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overallSignoffStatus": {
      "enum": [
        "open",
        "signed_off",
        "signed_off_with_waivers"
      ]
    },
    "overallSubmissionUse": {
      "type": "string"
    },
    "packet_id": {
      "type": "string"
    },
    "pendingActionIds": {
      "type": "array"
    },
    "referencedResources": {
      "type": "array"
    },
    "reviewerId": {
      "type": "string",
      "minLength": 1
    },
    "reviewerRole": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string"
    },
    "sourceBundleId": {
      "type": "string"
    },
    "submissionCandidateAllowed": {
      "type": "boolean"
    },
    "unresolvedBlockingActionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "waivedActionIds": {
      "type": "array"
    }
  }
}
