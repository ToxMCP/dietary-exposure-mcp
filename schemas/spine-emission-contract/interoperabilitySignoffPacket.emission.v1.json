{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.ngra.ai/dietary-exposure/emission/interoperabilitySignoffPacket.v1.json",
  "title": "interoperabilitySignoffPacket (producer strict emission contract)",
  "description": "Tightened additionalProperties:false mirror of the real DietaryRuntime.export_interoperability_signoff_packet emission (by_alias=True). Load-bearing review-arm fields (overallSignoffStatus, unresolvedBlockingActionIds, notes[]) are constrained.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overallSignoffStatus",
    "reviewerId",
    "reviewerRole"
  ],
  "properties": {
    "acknowledgedActionIds": {
      "type": "array"
    },
    "actionItems": {
      "type": "array"
    },
    "completedActionIds": {
      "type": "array"
    },
    "linkedDossierReadinessProfile": {
      "type": "string"
    },
    "linkedDossierReadinessStatus": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overallSignoffStatus": {
      "enum": [
        "open",
        "signed_off",
        "signed_off_with_waivers"
      ]
    },
    "packet_id": {
      "type": "string"
    },
    "pendingActionIds": {
      "type": "array"
    },
    "referencedResources": {
      "type": "array"
    },
    "reviewerId": {
      "type": "string",
      "minLength": 1
    },
    "reviewerRole": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string"
    },
    "sourceDossierId": {
      "type": "string"
    },
    "sourcePreviewProfileId": {
      "type": "string"
    },
    "sourceRemediationBundleId": {
      "type": "string"
    },
    "targetProfile": {
      "type": "object"
    },
    "unresolvedBlockingActionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "waivedActionIds": {
      "type": "array"
    }
  }
}
