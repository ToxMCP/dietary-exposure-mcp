    },
    "base_scenario_id": {
      "title": "Base Scenario Id",
      "type": "string"
    },
    "candidate_scenario_id": {
      "title": "Candidate Scenario Id",
      "type": "string"
    },
    "intake_window_semantic": {
      "$ref": "#/$defs/IntakeWindowSemantic"
