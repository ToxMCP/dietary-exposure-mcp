    "candidate_scenario_id",
    "intake_window_semantic",
    "base_total_intake_mg_per_kg_bw_per_day",
    "candidate_total_intake_mg_per_kg_bw_per_day",
    "intake_delta_mg_per_kg_bw_per_day",
    "contribution_deltas",
    "changed_assumptions",
    "dominant_drivers",
    "provenance"
