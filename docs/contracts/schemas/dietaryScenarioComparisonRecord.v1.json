        "base_value": {
          "title": "Base Value",
          "type": "number"
        },
        "candidate_value": {
          "title": "Candidate Value",
          "type": "number"
        },
        "absolute_delta": {
          "title": "Absolute Delta",
          "type": "number"
        },
        "relative_delta": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Relative Delta"
        }
      },
      "required": [
        "commodity",
        "base_value",
        "candidate_value",
        "absolute_delta"
      ],
      "title": "CommodityContributionDelta",
      "type": "object"
    },
