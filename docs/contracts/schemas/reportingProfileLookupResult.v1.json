          "type": "array"
        },
        "panelAnalytes": {
          "items": {
            "type": "string"
          },
          "title": "Panelanalytes",
          "type": "array"
        },
        "aggregationBasis": {
          "title": "Aggregationbasis",
          "type": "string"
        },
        "weightingBasisSummary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
