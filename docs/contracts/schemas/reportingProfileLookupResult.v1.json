          "$ref": "#/$defs/ContaminantFamily"
        },
        "metricKind": {
          "$ref": "#/$defs/ReportingMetricKind"
        },
        "profileRole": {
          "$ref": "#/$defs/ReportingProfileRole"
        },
        "submissionUse": {
          "$ref": "#/$defs/SubmissionUse"
        },
        "documentStatus": {
          "$ref": "#/$defs/DocumentStatus"
        },
        "reportedUnit": {
          "title": "Reportedunit",
          "type": "string"
        },
        "matrixGroups": {
          "items": {
            "type": "string"
          },
