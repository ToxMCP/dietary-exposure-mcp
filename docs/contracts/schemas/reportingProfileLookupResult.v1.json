    "profiles": {
      "items": {
        "$ref": "#/$defs/ReportingProfileRecord"
      },
      "title": "Profiles",
      "type": "array"
    },
    "recommendedPrimaryProfileIds": {
      "items": {
        "type": "string"
      },
      "title": "Recommendedprimaryprofileids",
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    }
