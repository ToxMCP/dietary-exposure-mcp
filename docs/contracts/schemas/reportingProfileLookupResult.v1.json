      "required": [
        "profileId",
        "displayName",
        "authority",
        "jurisdiction",
        "contaminantFamily",
        "metricKind",
        "profileRole",
        "submissionUse",
        "documentStatus",
        "reportedUnit",
        "aggregationBasis"
