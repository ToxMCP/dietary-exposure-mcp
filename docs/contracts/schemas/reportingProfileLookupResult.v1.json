        },
        "sourceIds": {
          "items": {
            "type": "string"
          },
          "title": "Sourceids",
          "type": "array"
        },
        "legalAuthorityIds": {
          "items": {
            "type": "string"
          },
          "title": "Legalauthorityids",
          "type": "array"
        },
        "referenceValueRecordIds": {
          "items": {
            "type": "string"
          },
          "title": "Referencevaluerecordids",
          "type": "array"
        },
        "notSubstitutableForProfileIds": {
          "items": {
            "type": "string"
          },
          "title": "Notsubstitutableforprofileids",
          "type": "array"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
