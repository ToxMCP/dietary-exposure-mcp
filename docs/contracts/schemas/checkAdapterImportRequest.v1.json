{
  "$defs": {
    "DietaryCommodityResidueInput": {
      "additionalProperties": false,
      "properties": {
        "commodity_code": {
          "minLength": 1,
          "title": "Commodity Code",
          "type": "string"
        },
        "residue_concentration_mg_per_kg": {
          "exclusiveMinimum": 0.0,
          "title": "Residue Concentration Mg Per Kg",
          "type": "number"
        },
        "lower_bound_mg_per_kg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Bound Mg Per Kg"
        },
        "upper_bound_mg_per_kg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper Bound Mg Per Kg"
        },
        "residue_unit": {
          "default": "mg/kg",
          "title": "Residue Unit",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/ResidueSourceType"
        },
        "processing_factor": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processing Factor"
        },
        "region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region Id"
        },
        "time_context": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time Context"
        },
        "review_status": {
          "default": "reviewed",
          "title": "Review Status",
          "type": "string"
        },
        "source_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "commodity_code",
        "residue_concentration_mg_per_kg",
        "source_type"
      ],
      "title": "DietaryCommodityResidueInput",
      "type": "object"
    },
    "FitForPurpose": {
      "enum": [
        "screening",
        "downstream_export",
        "benchmark",
        "comparison"
      ],
      "title": "FitForPurpose",
      "type": "string"
    },
    "IntakeWindowSemantic": {
      "enum": [
        "acute",
        "chronic"
      ],
      "title": "IntakeWindowSemantic",
      "type": "string"
    },
    "ModelFamily": {
      "enum": [
        "reference_dietary",
        "adapter_stub",
        "efsa_primo_adapter",
        "epa_deem_adapter"
      ],
      "title": "ModelFamily",
      "type": "string"
    },
    "ResidueSourceType": {
      "enum": [
        "monitoring",
        "modeled",
        "curated_default",
        "user_supplied",
        "reconciled"
      ],
      "title": "ResidueSourceType",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "point_estimate",
        "bounded_acute",
        "bounded_chronic"
      ],
      "title": "ScenarioClass",
      "type": "string"
    },
    "SourceOriginTag": {
      "enum": [
        "official_regulatory",
        "curated_derived",
        "illustrative_placeholder",
        "internal_operational"
      ],
      "title": "SourceOriginTag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "effective_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Date"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "originTag": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceOriginTag"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_id",
        "title"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "model_family": {
      "$ref": "#/$defs/ModelFamily"
    },
    "region_id": {
      "default": "eu_screening_default",
      "title": "Region Id",
      "type": "string"
    },
    "population_group": {
      "title": "Population Group",
      "type": "string"
    },
    "intake_window": {
      "$ref": "#/$defs/IntakeWindowSemantic"
    },
    "scenario_class": {
      "$ref": "#/$defs/ScenarioClass"
    },
    "chemical_identity": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Chemical Identity",
      "type": "object"
    },
    "residue_records": {
      "items": {
        "$ref": "#/$defs/DietaryCommodityResidueInput"
      },
      "maxItems": 2000,
      "title": "Residue Records",
      "type": "array"
    },
    "external_engine_version": {
      "minLength": 1,
      "title": "External Engine Version",
      "type": "string"
    },
    "external_case_id": {
      "default": "adapter-import-check",
      "minLength": 1,
      "title": "External Case Id",
      "type": "string"
    },
    "declared_total_intake_mg_per_kg_bw_per_day": {
      "minimum": 0.0,
      "title": "Declared Total Intake Mg Per Kg Bw Per Day",
      "type": "number"
    },
    "declared_lower_bound_mg_per_kg_bw_per_day": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Declared Lower Bound Mg Per Kg Bw Per Day"
    },
    "declared_upper_bound_mg_per_kg_bw_per_day": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Declared Upper Bound Mg Per Kg Bw Per Day"
    },
    "csv_text": {
      "maxLength": 5000000,
      "minLength": 1,
      "title": "Csv Text",
      "type": "string"
    },
    "fit_for_purpose": {
      "$ref": "#/$defs/FitForPurpose",
      "default": "screening"
    }
  },
  "required": [
    "model_family",
    "population_group",
    "intake_window",
    "scenario_class",
    "chemical_identity",
    "residue_records",
    "external_engine_version",
    "declared_total_intake_mg_per_kg_bw_per_day",
    "csv_text"
  ],
  "title": "CheckAdapterImportRequest",
  "type": "object"
}
