          "type": "boolean"
        },
        "valuePresent": {
          "title": "Valuepresent",
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "items": {},
