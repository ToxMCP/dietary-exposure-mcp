        },
        "displayName": {
          "title": "Displayname",
          "type": "string"
        },
        "targetFamily": {
          "title": "Targetfamily",
          "type": "string"
        },
        "ohtTemplates": {
          "items": {
            "type": "string"
          },
          "title": "Ohttemplates",
          "type": "array"
