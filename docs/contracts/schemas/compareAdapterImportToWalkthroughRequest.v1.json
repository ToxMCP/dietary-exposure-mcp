{
  "$defs": {
    "AdapterImportCheckProfileSelection": {
      "additionalProperties": false,
      "properties": {
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "population_group": {
          "title": "Population Group",
          "type": "string"
        },
        "intake_window": {
          "$ref": "#/$defs/IntakeWindowSemantic"
        },
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass"
        }
      },
      "required": [
        "region_id",
        "population_group",
        "intake_window",
        "scenario_class"
      ],
      "title": "AdapterImportCheckProfileSelection",
      "type": "object"
    },
    "AdapterImportCheckResult": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "default": "ok",
          "title": "Status",
          "type": "string"
        },
        "model_family": {
          "$ref": "#/$defs/ModelFamily"
        },
        "input_mode": {
          "default": "csv_v1",
          "title": "Input Mode",
          "type": "string"
        },
        "template_name": {
          "title": "Template Name",
          "type": "string"
        },
        "walkthrough_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Walkthrough Name"
        },
        "template_resource_uri": {
          "title": "Template Resource Uri",
          "type": "string"
        },
        "documentation_resource_uri": {
          "default": "docs://adapter-import-walkthroughs",
          "title": "Documentation Resource Uri",
          "type": "string"
        },
        "profile_selection": {
          "$ref": "#/$defs/AdapterImportCheckProfileSelection"
        },
        "chemical_identity": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Chemical Identity",
          "type": "object"
        },
        "declared_totals": {
          "$ref": "#/$defs/AdapterImportDeclaredTotals"
        },
        "input_headers": {
          "items": {
            "type": "string"
          },
          "title": "Input Headers",
          "type": "array"
        },
        "header_resolution": {
          "items": {
            "$ref": "#/$defs/AdapterImportHeaderResolution"
          },
          "title": "Header Resolution",
          "type": "array"
        },
        "unmapped_headers": {
          "items": {
            "type": "string"
          },
          "title": "Unmapped Headers",
          "type": "array"
        },
        "normalized_projection": {
          "$ref": "#/$defs/AdapterNormalizedProjection"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "model_family",
        "template_name",
        "template_resource_uri",
        "profile_selection",
        "chemical_identity",
        "declared_totals",
        "input_headers",
        "header_resolution",
        "normalized_projection"
      ],
      "title": "AdapterImportCheckResult",
      "type": "object"
    },
    "AdapterImportDeclaredTotals": {
      "additionalProperties": false,
      "properties": {
        "total_intake_mg_per_kg_bw_per_day": {
          "minimum": 0.0,
          "title": "Total Intake Mg Per Kg Bw Per Day",
          "type": "number"
        },
        "lower_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Bound Mg Per Kg Bw Per Day"
        },
        "upper_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper Bound Mg Per Kg Bw Per Day"
        }
      },
      "required": [
        "total_intake_mg_per_kg_bw_per_day"
      ],
      "title": "AdapterImportDeclaredTotals",
      "type": "object"
    },
    "AdapterImportHeaderResolution": {
      "additionalProperties": false,
      "properties": {
        "header": {
          "title": "Header",
          "type": "string"
        },
        "canonical_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Canonical Field"
        },
        "recognized": {
          "title": "Recognized",
          "type": "boolean"
        }
      },
      "required": [
        "header",
        "recognized"
      ],
      "title": "AdapterImportHeaderResolution",
      "type": "object"
    },
    "AdapterNormalizedProjection": {
      "additionalProperties": false,
      "properties": {
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass"
        },
        "intake_window": {
          "$ref": "#/$defs/IntakeWindowSemantic"
        },
        "population_group": {
          "title": "Population Group",
          "type": "string"
        },
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "body_weight_kg": {
          "exclusiveMinimum": 0.0,
          "title": "Body Weight Kg",
          "type": "number"
        },
        "total_intake_mg_per_kg_bw_per_day": {
          "minimum": 0.0,
          "title": "Total Intake Mg Per Kg Bw Per Day",
          "type": "number"
        },
        "lower_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Bound Mg Per Kg Bw Per Day"
        },
        "upper_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper Bound Mg Per Kg Bw Per Day"
        },
        "commodity_codes": {
          "items": {
            "type": "string"
          },
          "title": "Commodity Codes",
          "type": "array"
        },
        "commodity_contributions": {
          "items": {
            "$ref": "#/$defs/AdapterNormalizedProjectionContribution"
          },
          "title": "Commodity Contributions",
          "type": "array"
        },
        "dominant_commodity_codes": {
          "items": {
            "type": "string"
          },
          "title": "Dominant Commodity Codes",
          "type": "array"
        },
        "source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Ids",
          "type": "array"
        },
        "quality_flag_codes": {
          "items": {
            "type": "string"
          },
          "title": "Quality Flag Codes",
          "type": "array"
        },
        "limitation_codes": {
          "items": {
            "type": "string"
          },
          "title": "Limitation Codes",
          "type": "array"
        },
        "assumption_parameters": {
          "items": {
            "type": "string"
          },
          "title": "Assumption Parameters",
          "type": "array"
        }
      },
      "required": [
        "scenario_class",
        "intake_window",
        "population_group",
        "region_id",
        "body_weight_kg",
        "total_intake_mg_per_kg_bw_per_day",
        "commodity_codes",
        "commodity_contributions",
        "dominant_commodity_codes",
        "source_ids",
        "quality_flag_codes",
        "limitation_codes",
        "assumption_parameters"
      ],
      "title": "AdapterNormalizedProjection",
      "type": "object"
    },
    "AdapterNormalizedProjectionContribution": {
      "additionalProperties": false,
      "properties": {
        "commodity_code": {
          "title": "Commodity Code",
          "type": "string"
        },
        "canonical_name": {
          "title": "Canonical Name",
          "type": "string"
        },
        "foodex2_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Foodex2 Code"
        },
        "rpc_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rpc Code"
        },
        "rpcd_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rpcd Code"
        },
        "processed_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProcessedStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mapping_confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/MappingConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "contribution_mg_per_kg_bw_per_day": {
          "minimum": 0.0,
          "title": "Contribution Mg Per Kg Bw Per Day",
          "type": "number"
        },
        "fraction_of_total": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Fraction Of Total",
          "type": "number"
        },
        "residue_concentration_mg_per_kg": {
          "minimum": 0.0,
          "title": "Residue Concentration Mg Per Kg",
          "type": "number"
        },
        "consumption_kg_per_day": {
          "minimum": 0.0,
          "title": "Consumption Kg Per Day",
          "type": "number"
        },
        "applied_processing_factor": {
          "exclusiveMinimum": 0.0,
          "title": "Applied Processing Factor",
          "type": "number"
        },
        "lower_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Bound Mg Per Kg Bw Per Day"
        },
        "upper_bound_mg_per_kg_bw_per_day": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper Bound Mg Per Kg Bw Per Day"
        }
      },
      "required": [
        "commodity_code",
        "canonical_name",
        "contribution_mg_per_kg_bw_per_day",
        "fraction_of_total",
        "residue_concentration_mg_per_kg",
        "consumption_kg_per_day",
        "applied_processing_factor"
      ],
      "title": "AdapterNormalizedProjectionContribution",
      "type": "object"
    },
    "IntakeWindowSemantic": {
      "enum": [
        "acute",
        "chronic"
      ],
      "title": "IntakeWindowSemantic",
      "type": "string"
    },
    "MappingConfidence": {
      "enum": [
        "reviewed",
        "provisional",
        "heuristic"
      ],
      "title": "MappingConfidence",
      "type": "string"
    },
    "ModelFamily": {
      "enum": [
        "reference_dietary",
        "adapter_stub",
        "efsa_primo_adapter",
        "epa_deem_adapter"
      ],
      "title": "ModelFamily",
      "type": "string"
    },
    "ProcessedStatus": {
      "enum": [
        "raw_primary_commodity",
        "processed_derivative"
      ],
      "title": "ProcessedStatus",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "point_estimate",
        "bounded_acute",
        "bounded_chronic"
      ],
      "title": "ScenarioClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "check_result": {
      "$ref": "#/$defs/AdapterImportCheckResult"
    },
    "walkthrough_name": {
      "minLength": 1,
      "title": "Walkthrough Name",
      "type": "string"
    },
    "numeric_tolerance": {
      "default": 1e-12,
      "minimum": 0.0,
      "title": "Numeric Tolerance",
      "type": "number"
    }
  },
  "required": [
    "check_result",
    "walkthrough_name"
  ],
  "title": "CompareAdapterImportToWalkthroughRequest",
  "type": "object"
}
