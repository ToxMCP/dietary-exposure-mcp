{
  "$defs": {
    "CensoredDataPolicy": {
      "enum": [
        "lower_bound_zero",
        "middle_bound_half_lod_loq",
        "upper_bound_lod_loq",
        "three_bound_sensitivity"
      ],
      "title": "CensoredDataPolicy",
      "type": "string"
    },
    "CommodityReference": {
      "additionalProperties": false,
      "properties": {
        "taxonomy_id": {
          "title": "Taxonomy Id",
          "type": "string"
        },
        "commodity_code": {
          "title": "Commodity Code",
          "type": "string"
        },
        "canonical_name": {
          "title": "Canonical Name",
          "type": "string"
        },
        "food_group": {
          "title": "Food Group",
          "type": "string"
        },
        "mapping_status": {
          "title": "Mapping Status",
          "type": "string"
        },
        "foodex2_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Foodex2 Code"
        },
        "rpc_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rpc Code"
        },
        "rpcd_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rpcd Code"
        },
        "processed_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProcessedStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mapping_confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/MappingConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "matched_input_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched Input Code"
        },
        "source_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "taxonomy_id",
        "commodity_code",
        "canonical_name",
        "food_group",
        "mapping_status"
      ],
      "title": "CommodityReference",
      "type": "object"
    },
    "DietaryCommodityResidueRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "record_id": {
          "title": "Record Id",
          "type": "string"
        },
        "commodity": {
          "$ref": "#/$defs/CommodityReference"
        },
        "residue_concentration_mg_per_kg": {
          "exclusiveMinimum": 0.0,
          "title": "Residue Concentration Mg Per Kg",
          "type": "number"
        },
        "lower_bound_mg_per_kg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Bound Mg Per Kg"
        },
        "upper_bound_mg_per_kg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper Bound Mg Per Kg"
        },
        "residue_unit": {
          "default": "mg/kg",
          "title": "Residue Unit",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/ResidueSourceType"
        },
        "processing_factor": {
          "exclusiveMinimum": 0.0,
          "title": "Processing Factor",
          "type": "number"
        },
        "processing_factor_source_classification": {
          "$ref": "#/$defs/SourceClassification"
        },
        "processing_factor_source_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region Id"
        },
        "time_context": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time Context"
        },
        "review_status": {
          "title": "Review Status",
          "type": "string"
        },
        "source_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceBundle"
        },
        "quality_flags": {
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "limitations": {
          "items": {
            "$ref": "#/$defs/LimitationNote"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "commodity",
        "residue_concentration_mg_per_kg",
        "source_type",
        "processing_factor",
        "processing_factor_source_classification",
        "review_status",
        "provenance"
      ],
      "title": "DietaryCommodityResidueRecord",
      "type": "object"
    },
    "DietaryResidueProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "profile_id": {
          "title": "Profile Id",
          "type": "string"
        },
        "chemical_identity": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Chemical Identity",
          "type": "object"
        },
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "records": {
          "items": {
            "$ref": "#/$defs/DietaryCommodityResidueRecord"
          },
          "title": "Records",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceBundle"
        },
        "quality_flags": {
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "limitations": {
          "items": {
            "$ref": "#/$defs/LimitationNote"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "chemical_identity",
        "region_id",
        "records",
        "provenance"
      ],
      "title": "DietaryResidueProfile",
      "type": "object"
    },
    "DietarySurveyDatasetRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "datasetId": {
          "title": "Datasetid",
          "type": "string"
        },
        "regionId": {
          "title": "Regionid",
          "type": "string"
        },
        "populationGroup": {
          "title": "Populationgroup",
          "type": "string"
        },
        "records": {
          "items": {
            "$ref": "#/$defs/RawSurveyRecordInput"
          },
          "maxItems": 100000,
          "title": "Records",
          "type": "array"
        },
        "droppedRecordCount": {
          "default": 0,
          "minimum": 0,
          "title": "Droppedrecordcount",
          "type": "integer"
        },
        "dataLossFraction": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Datalossfraction",
          "type": "number"
        },
        "unmappedCommodityCodes": {
          "items": {
            "type": "string"
          },
          "title": "Unmappedcommoditycodes",
          "type": "array"
        },
        "bodyWeightConflictSubjectIds": {
          "items": {
            "type": "string"
          },
          "title": "Bodyweightconflictsubjectids",
          "type": "array"
        },
        "quality_flags": {
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "limitations": {
          "items": {
            "$ref": "#/$defs/LimitationNote"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "datasetId",
        "regionId",
        "populationGroup",
        "records"
      ],
      "title": "DietarySurveyDatasetRecord",
      "type": "object"
    },
    "HealthReference": {
      "additionalProperties": false,
      "properties": {
        "referenceType": {
          "$ref": "#/$defs/HealthReferenceType"
        },
        "value": {
          "exclusiveMinimum": 0.0,
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "default": "mg/kg bw/day",
          "title": "Unit",
          "type": "string"
        },
        "sourceId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sourceid"
        }
      },
      "required": [
        "referenceType",
        "value"
      ],
      "title": "HealthReference",
      "type": "object"
    },
    "HealthReferenceType": {
      "enum": [
        "ADI",
        "ARfD",
        "TDI",
        "BMDL",
        "MOE_REFERENCE_POINT"
      ],
      "title": "HealthReferenceType",
      "type": "string"
    },
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "MappingConfidence": {
      "enum": [
        "reviewed",
        "provisional",
        "heuristic"
      ],
      "title": "MappingConfidence",
      "type": "string"
    },
    "ProcessedStatus": {
      "enum": [
        "raw_primary_commodity",
        "processed_derivative"
      ],
      "title": "ProcessedStatus",
      "type": "string"
    },
    "ProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "defaults_version": {
          "default": "v1",
          "title": "Defaults Version",
          "type": "string"
        },
        "algorithm_version": {
          "title": "Algorithm Version",
          "type": "string"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "source_references": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source References",
          "type": "array"
        }
      },
      "required": [
        "algorithm_version",
        "generated_at"
      ],
      "title": "ProvenanceBundle",
      "type": "object"
    },
    "QualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "QualityFlag",
      "type": "object"
    },
    "RawSurveyRecordInput": {
      "additionalProperties": false,
      "properties": {
        "subjectId": {
          "title": "Subjectid",
          "type": "string"
        },
        "bodyWeightKg": {
          "exclusiveMinimum": 0.0,
          "title": "Bodyweightkg",
          "type": "number"
        },
        "daysInSurvey": {
          "minimum": 1,
          "title": "Daysinsurvey",
          "type": "integer"
        },
        "commodityCode": {
          "title": "Commoditycode",
          "type": "string"
        },
        "consumptionKgPerDay": {
          "minimum": 0.0,
          "title": "Consumptionkgperday",
          "type": "number"
        },
        "surveyWeight": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Surveyweight"
        },
        "samplingStratum": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Samplingstratum"
        },
        "samplingCluster": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Samplingcluster"
        },
        "surveyDayId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Surveydayid"
        }
      },
      "required": [
        "subjectId",
        "bodyWeightKg",
        "daysInSurvey",
        "commodityCode",
        "consumptionKgPerDay"
      ],
      "title": "RawSurveyRecordInput",
      "type": "object"
    },
    "ResidueSourceType": {
      "enum": [
        "monitoring",
        "modeled",
        "curated_default",
        "user_supplied",
        "reconciled"
      ],
      "title": "ResidueSourceType",
      "type": "string"
    },
    "ResidueUncertaintyDistribution": {
      "enum": [
        "point",
        "empirical",
        "uniform",
        "triangular",
        "lognormal",
        "censored_lognormal"
      ],
      "title": "ResidueUncertaintyDistribution",
      "type": "string"
    },
    "ResidueUncertaintyModel": {
      "additionalProperties": false,
      "properties": {
        "commodityCode": {
          "title": "Commoditycode",
          "type": "string"
        },
        "distribution": {
          "$ref": "#/$defs/ResidueUncertaintyDistribution"
        },
        "pointMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pointmgperkg"
        },
        "empiricalValuesMgPerKg": {
          "items": {
            "type": "number"
          },
          "maxItems": 10000,
          "minItems": 0,
          "title": "Empiricalvaluesmgperkg",
          "type": "array"
        },
        "minMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minmgperkg"
        },
        "modeMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modemgperkg"
        },
        "maxMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maxmgperkg"
        },
        "geometricMeanMgPerKg": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geometricmeanmgperkg"
        },
        "geometricSd": {
          "anyOf": [
            {
              "exclusiveMinimum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geometricsd"
        },
        "lodMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lodmgperkg"
        },
        "loqMgPerKg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Loqmgperkg"
        },
        "processingFactorCv": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Processingfactorcv"
        }
      },
      "required": [
        "commodityCode",
        "distribution"
      ],
      "title": "ResidueUncertaintyModel",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceClassification": {
      "enum": [
        "user_input",
        "curated_default",
        "mapped",
        "derived",
        "heuristic"
      ],
      "title": "SourceClassification",
      "type": "string"
    },
    "SourceOriginTag": {
      "enum": [
        "official_regulatory",
        "curated_derived",
        "illustrative_placeholder",
        "internal_operational"
      ],
      "title": "SourceOriginTag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "effective_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Date"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "originTag": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceOriginTag"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_id",
        "title"
      ],
      "title": "SourceReference",
      "type": "object"
    },
    "UncertaintyAssessmentMode": {
      "enum": [
        "two_dimensional_monte_carlo"
      ],
      "title": "UncertaintyAssessmentMode",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "dataset": {
      "$ref": "#/$defs/DietarySurveyDatasetRecord"
    },
    "residue_profile": {
      "$ref": "#/$defs/DietaryResidueProfile"
    },
    "assessmentMode": {
      "$ref": "#/$defs/UncertaintyAssessmentMode",
      "default": "two_dimensional_monte_carlo"
    },
    "randomSeed": {
      "title": "Randomseed",
      "type": "integer"
    },
    "outerIterationCount": {
      "default": 1000,
      "maximum": 50000,
      "minimum": 10,
      "title": "Outeriterationcount",
      "type": "integer"
    },
    "innerIterationCount": {
      "default": 1000,
      "maximum": 100000,
      "minimum": 10,
      "title": "Inneriterationcount",
      "type": "integer"
    },
    "residueUncertaintyModels": {
      "items": {
        "$ref": "#/$defs/ResidueUncertaintyModel"
      },
      "maxItems": 2000,
      "minItems": 1,
      "title": "Residueuncertaintymodels",
      "type": "array"
    },
    "censoredDataPolicy": {
      "$ref": "#/$defs/CensoredDataPolicy",
      "default": "three_bound_sensitivity"
    },
    "healthReference": {
      "anyOf": [
        {
          "$ref": "#/$defs/HealthReference"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "dataset",
    "residue_profile",
    "randomSeed",
    "residueUncertaintyModels"
  ],
  "title": "BuildUncertaintyIntakeAssessmentRequest",
  "type": "object"
}
