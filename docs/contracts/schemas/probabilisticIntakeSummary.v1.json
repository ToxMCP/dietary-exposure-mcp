{
  "$defs": {
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "ProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "defaults_version": {
          "default": "v1",
          "title": "Defaults Version",
          "type": "string"
        },
        "algorithm_version": {
          "title": "Algorithm Version",
          "type": "string"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "source_references": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source References",
          "type": "array"
        }
      },
      "required": [
        "algorithm_version",
        "generated_at"
      ],
      "title": "ProvenanceBundle",
      "type": "object"
    },
    "QualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "QualityFlag",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceOriginTag": {
      "enum": [
        "official_regulatory",
        "curated_derived",
        "illustrative_placeholder",
        "internal_operational"
      ],
      "title": "SourceOriginTag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "effective_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Date"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "originTag": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceOriginTag"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_id",
        "title"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "v1",
      "title": "Schema Version",
      "type": "string"
    },
    "summaryId": {
      "title": "Summaryid",
      "type": "string"
    },
    "datasetId": {
      "title": "Datasetid",
      "type": "string"
    },
    "populationGroup": {
      "title": "Populationgroup",
      "type": "string"
    },
    "chemicalIdentity": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Chemicalidentity",
      "type": "object"
    },
    "iterationCount": {
      "title": "Iterationcount",
      "type": "integer"
    },
    "randomSeed": {
      "title": "Randomseed",
      "type": "integer"
    },
    "cohortFingerprint": {
      "title": "Cohortfingerprint",
      "type": "string"
    },
    "totalSubjects": {
      "title": "Totalsubjects",
      "type": "integer"
    },
    "consumersOnlyCount": {
      "title": "Consumersonlycount",
      "type": "integer"
    },
    "zeroIntakePrevalence": {
      "title": "Zerointakeprevalence",
      "type": "number"
    },
    "meanIntakeMgPerKgBwPerDay": {
      "title": "Meanintakemgperkgbwperday",
      "type": "number"
    },
    "percentile95MgPerKgBwPerDay": {
      "title": "Percentile95Mgperkgbwperday",
      "type": "number"
    },
    "percentile99MgPerKgBwPerDay": {
      "title": "Percentile99Mgperkgbwperday",
      "type": "number"
    },
    "percentile999MgPerKgBwPerDay": {
      "title": "Percentile999Mgperkgbwperday",
      "type": "number"
    },
    "maxMgPerKgBwPerDay": {
      "title": "Maxmgperkgbwperday",
      "type": "number"
    },
    "consumersOnlyMeanMgPerKgBwPerDay": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Consumersonlymeanmgperkgbwperday"
    },
    "consumersOnlyPercentile95MgPerKgBwPerDay": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Consumersonlypercentile95Mgperkgbwperday"
    },
    "consumersOnlyPercentile99MgPerKgBwPerDay": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Consumersonlypercentile99Mgperkgbwperday"
    },
    "consumersOnlyPercentile999MgPerKgBwPerDay": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Consumersonlypercentile999Mgperkgbwperday"
    },
    "qualityFlags": {
      "items": {
        "$ref": "#/$defs/QualityFlag"
      },
      "title": "Qualityflags",
      "type": "array"
    },
    "limitations": {
      "items": {
        "$ref": "#/$defs/LimitationNote"
      },
      "title": "Limitations",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceBundle"
    }
  },
  "required": [
    "datasetId",
    "populationGroup",
    "chemicalIdentity",
    "iterationCount",
    "randomSeed",
    "cohortFingerprint",
    "totalSubjects",
    "consumersOnlyCount",
    "zeroIntakePrevalence",
    "meanIntakeMgPerKgBwPerDay",
    "percentile95MgPerKgBwPerDay",
    "percentile99MgPerKgBwPerDay",
    "percentile999MgPerKgBwPerDay",
    "maxMgPerKgBwPerDay",
    "provenance"
  ],
  "title": "ProbabilisticIntakeSummary",
  "type": "object"
}
